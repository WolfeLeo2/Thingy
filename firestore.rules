rules_version = '2';
// Single-user data scope: every read/write is scoped to the signed-in user.
// Single-user + free plan: classification runs on-device (no Cloud Functions), so the
// owner is the trusted classifier and may write any spaceItems.status. Ownership is the
// only invariant.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function ownsExisting() { return signedIn() && resource.data.userId == request.auth.uid; }
    function ownsIncoming() { return signedIn() && request.resource.data.userId == request.auth.uid; }
    match /items/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
      allow delete: if ownsExisting();
    }

    match /spaces/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
      allow delete: if ownsExisting();
    }

    match /spaceItems/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting() && ownsIncoming();
      allow delete: if ownsExisting();
    }
  }
}
