rules_version = '2';
// Owner-only: every image lives under items/{uid}/{file}, so we just
// check that the requesting user matches the path segment.
service firebase.storage {
  match /b/{bucket}/o {
    match /items/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
